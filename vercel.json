{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true
}
import { defineConfig, loadEnv } from 'vite';
import react from '@vitejs/plugin-react';
import path from 'path';

export default defineConfig(({ mode }) => {
  // Carrega as envs da pasta raiz para garantir que o config também as veja
  const env = loadEnv(mode, process.cwd(), '');

  return {
    plugins: [react()],
    resolve: {
      alias: {
        '@': path.resolve(__dirname, './client/src'),
      },
    },
    // Define fallbacks para variáveis que podem quebrar o build se estiverem vazias
    define: {
      'process.env.NODE_ENV': JSON.stringify(mode),
      // Isso evita o erro de "Identifier.bind" se a env estiver faltando
      'import.meta.env.VITE_SUPABASE_URL': JSON.stringify(env.VITE_SUPABASE_URL || ''),
      'import.meta.env.VITE_SUPABASE_ANON_KEY': JSON.stringify(env.VITE_SUPABASE_ANON_KEY || ''),
    },
    build: {
      outDir: 'dist',
      sourcemap: false, // Desativar em prod pode ajudar a isolar erros de parsing
      rollupOptions: {
        // Se o erro persistir, tente identificar se há uma lib externa problemática
        // external: ['nome-da-lib'], 
      }
    }
  };
});{
  "scripts": {
    "build": "vite build",
    "vercel-build": "vite build"
  }
